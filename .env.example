# ─────────────────────────────────────────────────────────────
# Homeward — environment template (Phase 0)
# Copy to .env at the repo root: `cp .env.example .env`
# The API loads this; missing REQUIRED vars cause a fail-fast on boot.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
API_PORT=4000
# Comma-separated origins allowed by CORS (the web dev server)
WEB_ORIGIN=http://localhost:5173

# Auth (REQUIRED) — used to sign the JWT session cookie
JWT_SECRET=dev-only-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Set true only behind HTTPS in production (secure cookie flag)
COOKIE_SECURE=false

# MongoDB (REQUIRED) — local docker-compose default below
MONGODB_URI=mongodb://localhost:27017/homeward

# Redis / BullMQ (REQUIRED) — dispatch queue connection (Phase 0: connection only)
REDIS_URL=redis://localhost:6379

# Public base URL of the API (absolute URLs for locally-stored media/posters)
PUBLIC_API_URL=http://localhost:4000
# Local media fallback directory (used when Cloudinary is NOT configured)
UPLOAD_DIR=./uploads

# Cloudinary (OPTIONAL) — when unset, photo upload + posters fall back to local
# disk storage served from /uploads. Set these to store media on Cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LINE Login (OPTIONAL in Phase 0)
# When LINE_CHANNEL_ID is empty, /auth/line runs the STUB verifier (dev only).
# Provide a real channel id/secret to switch to JWKS verification automatically.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Web app (apps/web) — Vite reads VITE_-prefixed vars
VITE_API_BASE_URL=http://localhost:4000
VITE_LIFF_ID=
